+const HEALTH_META = {
+  healthy: { label: "Healthy", className: "health-green" },
+  monitoring: { label: "Watching", className: "health-yellow" },
+  blocked: { label: "Blocked", className: "health-red" }
+};
+
+function projectStatusMeta(status) {
+  return STATUS_META[status] || { label: status || "Unknown", className: "status-staging" };
+}
+
+function healthMeta(status) {
+  return HEALTH_META[status] || { label: status || "Unknown", className: "health-yellow" };
+}
+
+function renderAgentPills(agents = []) {
+  return agents.map((agent) => `<span class="agent-pill">${agent}</span>`).join("");
+}
+
+function escapeHtml(value = "") {
+  return String(value)
+    .replaceAll("&", "&amp;")
+    .replaceAll("<", "&lt;")
+    .replaceAll(">", "&gt;")
+    .replaceAll('"', "&quot;")
+    .replaceAll("'", "&#39;");
+}
+
+function roleOwnerMap(agents = []) {
+  const mappings = [
+    ["Builder", "Builder"],
+    ["Reviewer", "Reviewer"],
+    ["Auditor", "Auditor"],
+    ["Supervisor", "Supervisor"]
+  ];
+
+  return mappings.reduce((acc, [projectRole, agentRole]) => {
+    const agent = (agents || []).find((item) => (item.roles || []).includes(agentRole));
+    if (agent) {
+      acc[projectRole] = {
+        name: agent.name,
+        model: agent.model,
+        label: `${agent.name} / ${agent.model}`,
+        status: agent.status
+      };
+    }
+    return acc;
+  }, {});
+}
+
+function enrichProjectWithRoster(project, agents = []) {
+  if (!project) return project;
+
+  const owners = roleOwnerMap(agents);
+  const normalizedAssignments = (project.agentAssignments || []).map((assignment) => {
+    const match = owners[assignment.role];
+    return match
+      ? {
+          ...assignment,
+          agent: `${match.name} / ${match.model}`,
+          health: match.status || assignment.health
+        }
+      : assignment;
+  });
+
+  const normalizedWorkflow = (project.workflow || []).map((phase) => ({
+    ...phase,
+    steps: (phase.steps || []).map((step) => ({
+      ...step,
+      roles: (step.roles || []).map((role) => {
+        const match = owners[role.role];
+        return match
+          ? {
+              ...role,
+              owner: match.label,
+              health: role.health || match.status
+            }
+          : role;
+      })
+    }))
+  }));
+
+  const activeOwner = owners.Builder;
+
+  return {
+    ...project,
+    activeScheme: project.activeScheme
+      ? {
+          ...project.activeScheme,
+          owner: activeOwner?.label || project.activeScheme.owner
+        }
+      : project.activeScheme,
+    agentAssignments: normalizedAssignments,
+    workflow: normalizedWorkflow
+  };
+}
+
+function renderOwnerCard(role) {
+  const meta = healthMeta(role.health);
+  return `
+    <article class="workflow-owner-card is-${role.done ? "done" : "active"}">
+      <div class="workflow-owner-top">
+        <strong>${role.role}</strong>
+        <span class="health-pill ${meta.className}">${meta.label}</span>
+      </div>
+      <span class="workflow-owner-name" title="${escapeHtml(role.owner || "")}">${role.owner}</span>
+      <small>${role.timer}</small>
+    </article>
+  `;
+}
+
+function workflowStep(step, index = 0) {
+  return `
+    <article class="workflow-step ${step.complete ? "is-complete" : ""}">
+      <div class="workflow-step-top">
+        <div>
+          <span class="workflow-step-kicker">Step ${index + 1} · ${step.scheme}</span>
+          <h5>${step.name}</h5>
+        </div>
+        <span class="workflow-step-status">${step.complete ? "Complete" : step.status || "In Progress"}</span>
+      </div>
+      <p class="workflow-step-copy">${step.purpose || "No purpose recorded."}</p>
+      <div class="workflow-owner-grid">
+        ${(step.roles || []).map(renderOwnerCard).join("")}
+      </div>
+      <div class="workflow-step-meta-grid">
+        <article class="summary-mini-card"><span>Scheme</span><strong>${step.scheme}</strong></article>
+        <article class="summary-mini-card"><span>Owner Movement</span><strong>${step.ownerNotification || "Not set"}</strong></article>
+        <article class="summary-mini-card"><span>SLA</span><strong>${step.sla || "Not set"}</strong></article>
+        <article class="summary-mini-card"><span>Watchdog</span><strong>${step.watchdog || "Not set"}</strong></article>
+      </div>
+      <div class="section-head-inline compact-head top-gap">
+        <h3 class="section-title">Done When</h3>
+        <span class="section-detail">Completion gate</span>
+      </div>
+      <div class="tag-row">
+        ${(step.doneWhen || []).map((item) => `<span class="meta-tag ${item.includes("Supervisor") ? "restriction-tag" : ""}">${item}</span>`).join("") || '<span class="meta-tag">No done criteria set</span>'}
+      </div>
+    </article>
+  `;
+}
+
+function buildTaskRow(task) {
+  return `
+    <li class="build-task-row ${task.done ? "is-complete" : ""}">
+      <div class="build-task-main">
+        <span class="build-task-check">${task.done ? "✔" : "○"}</span>
+        <div>
+          <strong>${task.title}</strong>
+          <span>${task.detail || ""}</span>
+        </div>
+      </div>
+      <div class="build-task-meta">
+        <span>${task.owner || "Unassigned"}</span>
+        <span>${task.dependsOn || "Ready"}</span>
+      </div>
+    </li>
+  `;
+}
+
+function renderAutomationRules(project) {
+  const rules = project.automationRules || {};
+  const notifications = rules.notifications || {};
+  const sla = rules.sla || {};
+  const watchdog = rules.watchdog || {};
+  return `
+    <div class="workflow-section-block top-gap">
+      <div class="section-head-inline compact-head">
+        <h3 class="section-title">Automation Rules</h3>
+        <span class="section-detail">Standard workflow controls</span>
+      </div>
+      <div class="summary-mini-grid">
+        <article class="summary-mini-card"><span>Completion Rule</span><strong>${rules.completionGate || "Not set"}</strong></article>
+        <article class="summary-mini-card"><span>Owner Movement Notify</span><strong>${notifications.channel || "Not set"}</strong></article>
+        <article class="summary-mini-card"><span>SLA Policy</span><strong>${sla.policy || "Not set"}</strong></article>
+        <article class="summary-mini-card"><span>Watchdog</span><strong>${watchdog.status || "Not set"}</strong></article>
+      </div>
+      <div class="tag-row top-gap">
+        ${(rules.notes || []).map((note) => `<span class="meta-tag restriction-tag">${note}</span>`).join("") || '<span class="meta-tag">No automation notes set</span>'}
+      </div>
+    </div>
+  `;
+}
+
+function renderWorkflowSections(project) {
+  const phases = project.workflow || [];
+  const activePhases = phases.filter((phase) => !(phase.complete || false));
+  const completedPhases = phases.filter((phase) => phase.complete || false);
+
+  return `
+    <div class="workflow-section-block">
+      <div class="section-head-inline compact-head">
+        <h3 class="section-title">Active Flow</h3>
+        <span class="section-detail">4-step tracked phase layout</span>
+      </div>
+      <div class="workflow-phase-stack">
+        ${activePhases.map((phase) => `
+          <section class="workflow-phase ${phase.active ? "is-active" : ""}">
+            <div class="workflow-phase-head">
+              <div>
+                <span class="workflow-phase-kicker">Phase</span>
+                <h4>${phase.name}</h4>
+                <p class="workflow-step-copy">${phase.objective || "No phase objective recorded."}</p>
+              </div>
+              <span class="workflow-phase-status">${phase.status}</span>
+            </div>
+            <div class="workflow-step-meta-grid">
+              <article class="summary-mini-card"><span>Current Step</span><strong>${phase.currentStep || "Not set"}</strong></article>
+              <article class="summary-mini-card"><span>Scheme Standard</span><strong>${phase.schemeStandard || "Standard Workflow"}</strong></article>
+              <article class="summary-mini-card"><span>Owner Movement</span><strong>${phase.ownerNotification || project.automationRules?.notifications?.channel || "Not set"}</strong></article>
+              <article class="summary-mini-card"><span>SLA / Watchdog</span><strong>${phase.slaWatchdog || "Tracked"}</strong></article>
+            </div>
+            <div class="workflow-step-list">
+              ${(phase.steps || []).map((step, index) => workflowStep(step, index)).join("") || '<div class="empty-open-project compact-empty"><span>No steps in this phase.</span></div>'}
+            </div>
+          </section>
+        `).join("")}
+      </div>
+    </div>
+
+    ${renderAutomationRules(project)}
+
+    <div class="workflow-section-block top-gap">
+      <div class="section-head-inline compact-head">
+        <h3 class="section-title">Completed</h3>
+        <span class="section-detail">Finished phases and steps</span>
+      </div>
+      <div class="workflow-phase-stack is-completed-stack">
+        ${completedPhases.map((phase) => `
+          <section class="workflow-phase is-complete-phase">
+            <div class="workflow-phase-head">
+              <div>
+                <span class="workflow-phase-kicker">Phase</span>
+                <h4>${phase.name}</h4>
+              </div>
+              <span class="workflow-phase-status">${phase.status}</span>
+            </div>
+            <div class="workflow-step-list">
+              ${(phase.steps || []).filter((step) => step.complete).map((step, index) => workflowStep(step, index)).join("") || '<div class="empty-open-project compact-empty"><span>No completed steps recorded.</span></div>'}
+            </div>
+          </section>
+        `).join("")}
+      </div>
+    </div>
+  `;
+}
+
+function deriveExecutionState(project, activeScheme) {
+  const workflowPhase = (project.workflow || []).find((phase) => phase.active) || project.workflow?.[0] || {};
+  const orchestrationPhase = project.orchestration?.phase || {};
+
+  return {
+    phase: project.phase || workflowPhase.name || orchestrationPhase.phaseHuman || "Not set",
+    step: workflowPhase.currentStep || `Step ${orchestrationPhase.step || 1}`,
+    owner: activeScheme.owner || orchestrationPhase.owner || "Unassigned",
+    scheme: activeScheme.name || orchestrationPhase.scheme || "Not set"
+  };
+}
+
+function renderExecutionStateBar(project, activeScheme, extraLabel = "Execution state") {
+  const execution = deriveExecutionState(project, activeScheme);
+
+  return `
+    <div class="active-scheme-bar compact-scheme-bar">
+      <div><span>Phase</span><strong>${execution.phase}</strong></div>
+      <div><span>Step</span><strong>${execution.step}</strong></div>
+      <div><span>Owner</span><strong>${execution.owner}</strong></div>
+      <div><span>Scheme</span><strong>${execution.scheme}</strong></div>
+      <div><span>View</span><strong>${extraLabel}</strong></div>
+    </div>
+  `;
+}
+
+function renderBuildTaskSections(project, activeScheme) {
+  const activeTasks = (project.buildTasks || []).filter((task) => !task.done);
+  const completedTasks = (project.buildTasks || []).filter((task) => task.done);
+
+  return `
+    <div class="build-task-shell">
+      ${renderExecutionStateBar(project, activeScheme, "Build task queue")}
+
+      <div class="section-head-inline compact-head">
+        <h3 class="section-title">Active Tasks</h3>
+        <span class="section-detail">Agent execution queue</span>
+      </div>
+      <ul class="build-task-list">
+        ${activeTasks.map(buildTaskRow).join("") || '<li class="empty-open-project compact-empty"><span>No active build tasks.</span></li>'}
+      </ul>
+
+      <div class="section-head-inline compact-head top-gap">
+        <h3 class="section-title">Completed Tasks</h3>
+        <span class="section-detail">Finished technical actions</span>
+      </div>
+      <ul class="build-task-list is-completed-stack">
+        ${completedTasks.map(buildTaskRow).join("") || '<li class="empty-open-project compact-empty"><span>No completed tasks yet.</span></li>'}
+      </ul>
+    </div>
+  `;
 }
 
