+
+function readState() {
+  try {
+    const parsed = JSON.parse(localStorage.getItem(ORCHESTRATION_KEY) || "null");
+    if (parsed && typeof parsed === "object") {
+      return hydrateState(parsed);
+    }
+  } catch {
+    // ignore corrupt persisted state
+  }
+
+  return createDefaultState();
+}
+
+function persistState(state) {
+  state.kernelVersion = ORCHESTRATION_KERNEL_VERSION;
+  state.runtimeKernelVersion = ORCHESTRATION_KERNEL_VERSION;
+  localStorage.setItem(ORCHESTRATION_KEY, JSON.stringify(state));
+}
+
+function hasKernelMismatch(state) {
+  return state?.kernelVersion !== ORCHESTRATION_KERNEL_VERSION || state?.runtimeKernelVersion !== ORCHESTRATION_KERNEL_VERSION;
