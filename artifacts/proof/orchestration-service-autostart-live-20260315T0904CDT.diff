+  state.notificationQueue = [];
+  state.lastMovementAt = timestamp;
+  appendEvent(state, {
+    type: "CYCLE_RESTARTED",
+    detail: "Supervisor FINAL_VERDICT PASS closed the cycle and started the next Builder step.",
+    meta: { owner: "BUILDER", ownerModel: STEP_META.BUILDER.model, timestamp }
+  });
+}
+
+function queueToBuildTasks(queue = []) {
+  return queue.map((task) => ({
+    title: task.title,
+    detail: task.detail,
+    owner: task.owner,
+    dependsOn: task.dependsOn,
+    done: task.status === "done"
+  }));
+}
+
+function buildWorkflow(state) {
+  const activeOwner = state.phase?.owner || "BUILDER";
+  const activeStep = state.phase?.step || 1;
+  const roleTimer = state.blocker ? "Blocked" : state.autoRun ? "Execution active" : "Manual hold";
+
+  const roleMeta = {
+    BUILDER: { role: "Builder", health: "healthy" },
+    REVIEWER: { role: "Reviewer", health: "monitoring" },
+    AUDITOR: { role: "Auditor", health: "healthy" },
+    SUPERVISOR: { role: "Supervisor", health: "healthy" }
+  };
+
+  const steps = STEP_ORDER.map((ownerKey, index) => {
+    const meta = roleMeta[ownerKey];
+    const stepNumber = index + 1;
+    const isActive = stepNumber === activeStep;
+    const isComplete = stepNumber < activeStep;
+
+    return {
+      name: `Step ${stepNumber} — ${meta.role}`,
+      scheme: isActive ? state.phase?.scheme || "ARTIFACTS_REVIEWED" : "SCHEME_PENDING",
+      status: isComplete ? "Complete" : isActive ? state.phase?.status || "IN_PROGRESS" : "Queued",
+      complete: isComplete,
+      purpose: isActive
+        ? state.activeSlice?.title || `${meta.role} is executing the active Atlantis slice.`
+        : `${meta.role} takes over after the prior owner completes a real artifact-backed handoff.`,
+      ownerNotification: isActive ? state.phase?.nextTrigger || "handoff_pending" : "Await prior step completion",
+      sla: state.blocker ? "Needs intervention" : "Artifact-backed execution required",
+      watchdog: state.blocker ? state.blocker.code : "healthy",
+      doneWhen: [
+        `${meta.role} has touched the system before speaking`,
+        "A real artifact exists before step advancement",
+        `Scheme ladder progresses through ${SCHEME_ORDER.join(" → ")}`,
+        `${meta.role} completes with proof-backed handoff evidence`
+      ],
+      roles: STEP_ORDER.map((roleKey, roleIndex) => ({
+        role: roleMeta[roleKey].role,
+        owner: roleKey === activeOwner ? "Active" : roleIndex < index ? "Complete" : "Standby",
+        timer: roleKey === activeOwner && isActive ? roleTimer : roleIndex < index ? "done" : "queued",
+        health: roleKey === activeOwner && isActive ? (state.blocker ? "blocked" : roleMeta[roleKey].health) : roleMeta[roleKey].health,
+        done: roleIndex < index || (isComplete && roleKey === ownerKey)
+      }))
+    };
+  });
+
+  return [
+    {
+      name: state.phase?.phaseHuman || "Build",
+      objective: "Advance Atlantis through the standard engineering workflow with real artifacts at each step.",
+      status: state.phase?.status || "IN_PROGRESS",
+      active: true,
+      currentStep: `Step ${activeStep} — ${roleMeta[activeOwner]?.role || "Builder"}`,
+      schemeStandard: SCHEME_ORDER.join(" → "),
+      ownerNotification: "Post completion + next move to 1480062095348207648",
+      slaWatchdog: state.blocker ? `Blocked · ${state.blocker.code}` : "Execution proof required before speaking",
+      steps
+    }
+  ];
+}
+
+function appendEvent(state, event) {
+  state.eventLog = [
+    { at: new Date().toISOString(), ...event },
+    ...(state.eventLog || [])
+  ].slice(0, 40);
+}
+
+function latestProofSnapshot(state, owner = null) {
+  const proof = owner
+    ? (Array.isArray(state.proofLog) ? state.proofLog.find((entry) => (entry?.owner || entry?.meta?.owner) === owner) : null)
+    : (Array.isArray(state.proofLog) && state.proofLog.length ? state.proofLog[0] : null);
+  return {
+    filesChanged: proof?.files || [],
+    artifactPath: proof?.artifacts?.[0] || proof?.artifactPath || proof?.meta?.artifactPath || null,
+    validationResult: proof?.validationResult || proof?.meta?.validationResult || proof?.validations?.join(" | ") || "No validation recorded",
+    commandExecuted: proof?.summary || proof?.title || "Runtime proof gate advanced"
+  };
+}
+
+function hasReviewerPass(state) {
+  return reviewerHasPassProof(state);
+}
+
+function queueMovementNotification(state, fromScheme, toScheme, owner, trigger, timestamp = new Date().toISOString()) {
+  const snapshot = latestProofSnapshot(state, owner);
+  const meta = STEP_META[owner] || STEP_META.BUILDER;
+  const movement = {
+    type: "SCHEME_MOVEMENT",
+    phase: meta.phaseHuman,
+    step: meta.step,
