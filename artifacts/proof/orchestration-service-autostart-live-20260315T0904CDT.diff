+  state.transitionInFlight = null;
+  return timestamp;
+}
+
+function consumePassArtifactAndAutoStartNextOwner(state, owner) {
+  if (state.blocker || !state.autoRun) return false;
+  if (!ownerHasPassArtifact(state, owner)) return false;
+
+  const transitions = {
+    BUILDER: {
+      nextOwner: "REVIEWER",
+      nextScheme: "DELTA_PROOF",
+      trigger: "builder_pass_artifact_consumed",
+      nextTrigger: "reviewer_execution"
+    },
+    REVIEWER: {
+      nextOwner: "AUDITOR",
+      nextScheme: "EXECUTION_PROOF",
+      trigger: "reviewer_pass_artifact_consumed",
+      nextTrigger: "auditor_execution"
+    },
+    AUDITOR: {
+      nextOwner: "SUPERVISOR",
+      nextScheme: "ACCEPTANCE_CHECK",
+      trigger: "auditor_pass_artifact_consumed",
+      nextTrigger: "supervisor_execution"
