+  repaired.phase.status = repaired.autoRun ? "IN_PROGRESS" : "PAUSED";
+  repaired.phase.nextTrigger = repaired.autoRun ? (repaired.phase.nextTrigger || "refresh_validation") : "manual_resume";
+  appendEvent(repaired, {
+    type: "KERNEL_STATE_REPAIRED",
+    detail: reason,
+    meta: {
