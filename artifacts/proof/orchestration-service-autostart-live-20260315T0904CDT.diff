+        } else {
+          state.phase.status = "PAUSED";
+          state.phase.lastProofEvent = "STOP_GATE_REACHED";
+          state.phase.nextTrigger = "manual_resume";
+          appendEvent(state, { type: "STOP_GATE_REACHED", detail: "Supervisor FINAL_VERDICT PASS reached the product stop gate." });
+        }
+      }
+    }
+  };
+
+  if (["BUILDER", "REVIEWER", "AUDITOR"].includes(activeOwner) && consumePassArtifactAndAutoStartNextOwner(state, activeOwner)) {
+    return true;
+  }
+
+  const transition = transitions[activeOwner];
+  if (transition?.ready()) {
+    transition.run();
+    return true;
+  }
+
+  if (hasCurrentOwnerPassArtifact) {
+    const proof = latestProofSnapshot(state, activeOwner);
+    state.phase.status = "BLOCKED";
+    state.phase.lastProofEvent = `BLOCKED:${activeOwner}_PASS_NO_TRANSITION`;
+    state.phase.nextTrigger = "manual_resume";
+    state.blocker = {
+      code: "PASS_ARTIFACT_DID_NOT_ADVANCE",
+      detail: `Proof exists but transition did not fire because state.phase.owner=${state.phase?.owner || "unknown"}`,
+      artifactPath: proof.artifactPath || "none",
+      validationResult: proof.validationResult,
+      exactStateFieldPreventingAdvancement: "state.phase.owner",
+      since: state.blocker?.since || new Date().toISOString()
+    };
+    appendEvent(state, {
+      type: "PASS_ARTIFACT_DID_NOT_ADVANCE",
+      detail: state.blocker.detail,
+      meta: state.blocker
+    });
+  }
+
+  return false;
+}
+
+export function createOrchestrationService({ pollIntervalMs = 4000 } = {}) {
+  let state = readState();
+  if (hasKernelMismatch(state)) {
+    state = repairKernelState(state, "create_service_kernel_mismatch");
+  }
+  persistState(state);
+
+  const touch = () => {
+    state.metrics.lastSupervisorTickAt = new Date().toISOString();
+    persistState(state);
+  };
+
+  const markTaskDone = (taskId) => {
+    const task = state.queue.find((item) => item.id === taskId);
+    if (task) task.status = "done";
+  };
+
+  const nextQueueTask = () => state.queue.find((item) => item.status !== "done") || null;
+
+  const syncFromRefresh = ({ ok, source, warning, error }) => {
+    touch();
+
+    if (ok) {
+      state.metrics.refreshSuccesses += 1;
+      state.metrics.lastHealthyAt = new Date().toISOString();
+
+      if (source === "openclaw-live") {
+        state.metrics.fallbackSince = null;
+        if (state.blocker?.code === "REFRESH_FAILURE") {
+          state.blocker = null;
+        }
+        appendEvent(state, { type: "LIVE_REFRESH_OK", detail: "Live feed refresh succeeded." });
+      } else {
+        state.metrics.fallbackSince = state.metrics.fallbackSince || new Date().toISOString();
+        appendEvent(state, { type: "FALLBACK_ACTIVE", detail: warning || "Fallback data in use." });
+      }
+    } else {
+      state.metrics.refreshFailures += 1;
+      state.blocker = {
+        code: "REFRESH_FAILURE",
+        detail: error?.message || "Unknown refresh failure",
+        since: state.blocker?.since || new Date().toISOString()
+      };
+      appendEvent(state, { type: "REFRESH_FAILURE", detail: error?.message || "Unknown refresh failure" });
+    }
+
+    markTaskDone("validator-gate");
+    markTaskDone("blocker-escalation");
+    persistState(state);
+  };
+
+  const runSupervisorTick = () => {
+    if (hasKernelMismatch(state) || state.needsKernelReload) {
+      state = repairKernelState(state, "supervisor_tick_kernel_mismatch");
+    }
+
+    touch();
+    markTaskDone("persisted-state");
+    markTaskDone("next-slice-selector");
+    markTaskDone("event-emission");
+    markTaskDone("product-proof-surface");
+
+    const nextTask = nextQueueTask();
+    state.activeSlice = nextTask
+      ? {
+          ...(state.activeSlice || {}),
+          id: nextTask.id,
+          title: nextTask.title,
+          status: state.activeSlice?.status || "ready"
+        }
+      : {
+          ...(state.activeSlice || {}),
+          id: "phase-review",
+          title: "Phase completion review",
+          status: state.activeSlice?.status || "ready"
+        };
+
+    if (!state.autoRun) {
+      state.phase.status = "PAUSED";
+      state.phase.nextTrigger = "manual_resume";
+      persistState(state);
+      return state;
+    }
+
+    if (state.blocker) {
+      state.phase.status = state.blocker.code === "HARD_BLOCKED" ? "HARD_BLOCKED" : "BLOCKED";
+      state.phase.nextTrigger = state.blocker.code === "HARD_BLOCKED" ? "hard_blocked_manual_fix_required" : "blocker_clear";
+      persistState(state);
+      return state;
+    }
+
+    state.phase.step = state.phase.step || 1;
+    state.phase.owner = state.phase.owner || "BUILDER";
+    state.phase.scheme = SCHEME_ORDER.find((scheme) => scheme === state.phase.scheme) || "ARTIFACTS_REVIEWED";
+    state.phase.status = state.phase.status === "PASS" ? "PASS" : (state.phase.status === "COMPLETE" ? "COMPLETE" : "IN_PROGRESS");
+
+    const advanced = maybeAdvanceWorkflow(state);
+    if (advanced) {
+      persistState(state);
+      return state;
+    }
+
+    if (!nextTask) {
+      if (state.phase.owner === "SUPERVISOR") {
+        state.phase.scheme = "FINAL_VERDICT";
+        state.phase.status = state.phase.status === "PAUSED" ? "PAUSED" : "READY_FOR_PHASE_CLOSE";
+        state.phase.lastProofEvent = state.phase.status === "PAUSED" ? state.phase.lastProofEvent : "QUEUE_EMPTY_REVIEW_READY";
+        state.phase.nextTrigger = state.phase.status === "PAUSED" ? "manual_resume" : "supervisor_closeout";
+        appendEvent(state, { type: "QUEUE_EMPTY_REVIEW_READY", detail: "All orchestration tasks are complete." });
+      }
+      persistState(state);
+      return state;
+    }
+
+    persistState(state);
+    return state;
+  };
+
+  const decorateProject = (project) => {
+    if (!project || project.id !== state.projectId) return project;
+
+    const queue = state.queue || [];
+    const completed = queue.filter((item) => item.status === "done").length;
+    const progress = queue.length ? Math.round((completed / queue.length) * 100) : project.progress || 0;
+
+    return {
+      ...project,
+      status: state.blocker ? "staging" : project.status || "in_motion",
+      phase: state.phase.phaseHuman,
+      progress,
+      activeScheme: {
+        ...(project.activeScheme || {}),
+        name: state.phase.scheme,
+        owner: `Step ${state.phase.step} — ${state.phase.owner}`,
+        elapsed: state.metrics.lastSupervisorTickAt ? new Date(state.metrics.lastSupervisorTickAt).toLocaleTimeString() : "Waiting",
+        sla: state.blocker ? "Blocked" : `${Math.round(pollIntervalMs / 1000)}s supervisor tick`,
+        watchdog: state.blocker ? state.blocker.code : "Execution active"
+      },
+      automationRules: {
+        ...(project.automationRules || {}),
+        completionGate: state.phase.stopTarget,
+        notifications: { channel: "1480062095348207648", trigger: "Scheme completion + next move" },
+        sla: { policy: state.blocker ? "Escalate on blocker" : "Every owner must touch system before speaking" },
+        watchdog: { status: state.blocker ? "BLOCKED" : "ACTIVE" },
+        notes: [
+          `Auto-run: ${state.autoRun ? "enabled" : "disabled"}`,
+          `Automation target: ${state.automationTargetScheme || "Not set"}`,
+          `Last proof: ${state.phase.lastProofEvent}`,
+          `Next trigger: ${state.phase.nextTrigger}`,
+          `Scheme order: ${SCHEME_ORDER.join(" → ")}`
+        ]
+      },
+      workflow: buildWorkflow(state),
+      buildTasks: queueToBuildTasks(queue),
+      proof: state.proofLog || [],
+      orchestration: state
+    };
+  };
+
+  return {
+    getState: () => structuredClone(state),
+    getKernelVersion: () => ORCHESTRATION_KERNEL_VERSION,
+    ensureCurrentKernel() {
+      if (hasKernelMismatch(state) || state.needsKernelReload) {
+        state = repairKernelState(state, "ensure_current_kernel");
+      }
+      return structuredClone(state);
+    },
+    drainNotifications() {
+      const queued = [...(state.notificationQueue || [])].reverse();
+      state.notificationQueue = [];
+      persistState(state);
+      return queued;
+    },
+    setAutoRun(enabled) {
+      state.autoRun = Boolean(enabled);
+      persistState(state);
+      return this.getState();
+    },
+    runSupervisorTick,
+    syncFromRefresh,
+    decorateProject,
+    persist() {
+      persistState(state);
+    }
+  };
+}
