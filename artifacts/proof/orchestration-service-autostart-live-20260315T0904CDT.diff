+  });
+  persistState(repaired);
+  return repaired;
+}
+
+function nextScheme(currentScheme) {
+  const index = SCHEME_ORDER.indexOf(currentScheme);
+  if (index === -1) return SCHEME_ORDER[0];
+  return SCHEME_ORDER[Math.min(index + 1, SCHEME_ORDER.length - 1)];
+}
+
+function hasOwnerProof(state, owner) {
+  return Array.isArray(state.proofLog) && state.proofLog.some((proof) => {
+    const proofOwner = proof?.owner || proof?.meta?.owner || null;
+    const proofModel = proof?.ownerModel || proof?.meta?.ownerModel || null;
+    const stepMeta = STEP_META[owner] || null;
+    return proofOwner === owner && (!stepMeta?.model || proofModel === stepMeta.model);
+  });
+}
+
+function builderHasProof(state) {
+  return hasOwnerProof(state, "BUILDER");
+}
+
+function ownerHasPassArtifact(state, owner) {
+  const stepMeta = STEP_META[owner] || null;
+  return Array.isArray(state.proofLog) && state.proofLog.some((proof) => {
+    const proofOwner = proof?.owner || proof?.meta?.owner || null;
+    const proofModel = proof?.ownerModel || proof?.meta?.ownerModel || null;
+    const validationResult = String(proof?.validationResult || proof?.meta?.validationResult || "").toUpperCase();
+    const validations = Array.isArray(proof?.validations) ? proof.validations.map((v) => String(v).toUpperCase()) : [];
+    const hasArtifact = Boolean(proof?.artifacts?.length || proof?.artifactPath || proof?.meta?.artifactPath);
+    const hasPass = validationResult.includes("PASS") || validations.some((entry) => entry.includes("PASS"));
+    return proofOwner === owner && (!stepMeta?.model || proofModel === stepMeta.model) && hasArtifact && hasPass;
+  });
+}
+
+function reviewerHasPassProof(state) {
+  return Array.isArray(state.eventLog) && state.eventLog.some((event) => event?.type === "REVIEWER_VALIDATION_PASS" && event?.meta?.owner === "REVIEWER" && event?.meta?.ownerModel === STEP_META.REVIEWER.model)
+    || ownerHasPassArtifact(state, "REVIEWER");
+}
+
+function auditorHasPassProof(state) {
+  return Array.isArray(state.eventLog) && state.eventLog.some((event) => event?.type === "AUDITOR_VALIDATION_PASS" && event?.meta?.owner === "AUDITOR" && event?.meta?.ownerModel === STEP_META.AUDITOR.model)
+    || ownerHasPassArtifact(state, "AUDITOR");
+}
+
+function supervisorHasFinalVerdictPass(state) {
+  return state.phase?.scheme === "FINAL_VERDICT" && ownerHasPassArtifact(state, "SUPERVISOR");
