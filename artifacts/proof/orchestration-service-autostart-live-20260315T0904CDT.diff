+  appendEvent(state, {
+    type: "SCHEME_MOVEMENT",
+    detail: `${owner} ${fromScheme} → ${toScheme}`,
+    meta: movement
+  });
+}
+
+function transitionToOwner(state, { owner, toScheme, status = "IN_PROGRESS", trigger, phaseHuman, nextTrigger }) {
+  const meta = STEP_META[owner] || STEP_META.BUILDER;
+  const previousScheme = state.phase?.scheme || toScheme;
+  const timestamp = new Date().toISOString();
+
+  state.transitionInFlight = {
+    owner,
+    toScheme,
+    trigger,
+    startedAt: timestamp
+  };
+
+  state.phase.step = meta.step;
+  state.phase.owner = owner;
+  state.phase.phaseHuman = phaseHuman || meta.phaseHuman;
+  state.phase.scheme = toScheme;
+  state.phase.status = status;
+  state.phase.lastProofEvent = `STEP_STARTED:${owner}`;
+  state.phase.nextTrigger = nextTrigger || trigger;
+  state.phase.stepStartedAt = timestamp;
+  state.phase.slaArmedAt = timestamp;
+  state.activeSlice = {
+    ...(state.activeSlice || {}),
+    status: "running",
+    owner,
+    startedAt: timestamp,
+    slaArmedAt: timestamp
+  };
+  state.metrics = {
+    ...(state.metrics || {}),
+    lastSupervisorTickAt: timestamp,
+    slaArmedAt: timestamp
+  };
+
+  appendEvent(state, {
+    type: "STEP_STARTED",
+    detail: `${owner}`,
+    meta: { owner, step: meta.step, scheme: toScheme, trigger, timestamp }
+  });
+  appendEvent(state, {
+    type: "SLA_ARMED",
+    detail: `${owner}`,
+    meta: { owner, step: meta.step, scheme: toScheme, armedAt: timestamp, trigger }
