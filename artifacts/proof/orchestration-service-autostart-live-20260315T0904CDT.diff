+
+function hydrateState(parsed = {}) {
+  const fallback = createDefaultState();
+  return {
+    ...fallback,
+    ...parsed,
+    kernelVersion: ORCHESTRATION_KERNEL_VERSION,
+    runtimeKernelVersion: ORCHESTRATION_KERNEL_VERSION,
