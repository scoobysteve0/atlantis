+  state.phase = {
+    ...DEFAULT_PHASE,
+    phaseNumber: Number(state.phase?.phaseNumber || DEFAULT_PHASE.phaseNumber) + 1,
+    stepStartedAt: timestamp,
+    slaArmedAt: timestamp,
