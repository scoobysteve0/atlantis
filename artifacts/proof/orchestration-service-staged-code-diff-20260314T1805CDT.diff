+const ORCHESTRATION_KEY = "atlantis.orchestration.v1";
+const DEFAULT_PROJECT_ID = "atlantis-agent-monitoring";
+const STEP_ORDER = ["BUILDER", "REVIEWER", "AUDITOR", "SUPERVISOR"];
+const SCHEME_ORDER = [
+  "ARTIFACTS_REVIEWED",
+  "DELTA_PROOF",
+  "EXECUTION_PROOF",
+  "ACCEPTANCE_CHECK",
+  "FINAL_VERDICT"
+];
+const DEFAULT_PHASE = {
+  phaseNumber: 1,
+  phaseHuman: "Build",
+  step: 1,
+  owner: "BUILDER",
+  scheme: "ARTIFACTS_REVIEWED",
+  status: "IN_PROGRESS",
+  stopTarget: "REAL_ARTIFACT_REQUIRED_FOR_STEP_ADVANCE",
+  lastProofEvent: "STEP1_STARTED:ARTIFACTS_REVIEWED",
+  nextTrigger: "builder_execution"
+};
+
+const DEFAULT_TASKS = [
+  {
+    id: "persisted-state",
+    title: "Persist orchestration state",
+    detail: "Keep phase, owner, proof, and blockers durable across restarts.",
+    owner: "BUILDER",
+    dependsOn: "Ready",
+    status: "done"
+  },
+  {
+    id: "next-slice-selector",
+    title: "Select next slice automatically",
+    detail: "Choose unfinished implementation work from real state instead of waiting for chat prompts.",
+    owner: "SUPERVISOR",
+    dependsOn: "persisted-state",
+    status: "done"
+  },
+  {
+    id: "validator-gate",
+    title: "Advance only on proof",
+    detail: "Move owners and statuses from refresh/validation outcomes, not intention.",
+    owner: "REVIEWER",
+    dependsOn: "next-slice-selector",
+    status: "done"
+  },
+  {
+    id: "event-emission",
+    title: "Emit workflow updates from supervisor state",
+    detail: "Expose live workflow progress inside Atlantis project data.",
+    owner: "AUDITOR",
+    dependsOn: "validator-gate",
+    status: "done"
+  },
+  {
+    id: "blocker-escalation",
+    title: "Escalate on real blockers",
+    detail: "Mark BLOCKED when live sync degrades or no next slice exists.",
+    owner: "SUPERVISOR",
+    dependsOn: "event-emission",
+    status: "done"
+  },
+  {
+    id: "product-proof-surface",
+    title: "Show proof inside Atlantis product",
+    detail: "Expose changed files, validations, and artifacts in the project detail UI.",
+    owner: "BUILDER",
+    dependsOn: "event-emission",
+    status: "done"
+  }
+];
+
+const DEFAULT_PROOF = [
+  {
+    id: "proof-product-surface",
+    title: "In-product proof surface",
+    kind: "diff",
+    status: "done",
+    summary: "Atlantis project detail now has a Proof tab for changed files, validation, and artifacts.",
+    files: [
+      "src/renderer/js/ui/dashboard-ui.js",
+      "src/renderer/js/core/orchestration-service.js",
+      "src/renderer/css/styles.css"
+    ],
+    validations: [
+      "node --check src/renderer/js/ui/dashboard-ui.js",
+      "node --check src/renderer/js/core/orchestration-service.js"
+    ],
+    artifacts: [
+      "artifacts/product-proof-surface-20260314T1428CDT.md"
+    ]
+  },
+  {
+    id: "proof-orchestration-layer",
+    title: "Persisted supervisor / runner orchestration",
+    kind: "diff",
+    status: "done",
+    summary: "Added persisted orchestration state, supervisor ticks, and project decoration from real runtime state.",
+    files: [
+      "src/renderer/js/main.js",
+      "src/renderer/js/core/store.js",
+      "src/renderer/js/core/data-service.js",
+      "src/renderer/js/core/orchestration-service.js"
+    ],
+    validations: [
+      "node --check src/renderer/js/main.js",
+      "node --check src/renderer/js/core/store.js",
+      "node --check src/renderer/js/core/data-service.js",
+      "node --check src/renderer/js/core/orchestration-service.js"
+    ],
+    artifacts: [
+      "artifacts/orchestration-layer-proof-20260314T1324CDT.md"
+    ]
+  },
+  {
+    id: "proof-stall-escalation",
+    title: "Stall escalation notifications",
+    kind: "runtime",
+    status: "done",
+    summary: "Added repeated-failure and prolonged-fallback escalation notifications with cooldown behavior.",
+    files: [
+      "src/renderer/index.html",
+      "src/renderer/js/main.js"
+    ],
+    validations: [
+      "node --check src/renderer/js/main.js"
+    ],
+    artifacts: [
+      "artifacts/stall-escalation-proof-20260314T1219CDT.md"
+    ]
+  },
+  {
+    id: "proof-notification-controls",
+    title: "Notification controls",
+    kind: "diff",
+    status: "done",
+    summary: "Added settings toggles for live-feed and save/failure notifications with persisted preferences.",
+    files: [
+      "src/renderer/index.html",
+      "src/renderer/css/styles.css",
+      "src/renderer/js/main.js"
+    ],
+    validations: [
+      "node --check src/renderer/js/main.js"
+    ],
+    artifacts: [
+      "artifacts/notification-controls-proof-20260314T1131CDT.md"
+    ]
+  }
+];
+
+function readState() {
+  try {
+    const parsed = JSON.parse(localStorage.getItem(ORCHESTRATION_KEY) || "null");
+    if (parsed && typeof parsed === "object") {
+      return {
+        ...parsed,
+        proofLog: Array.isArray(parsed.proofLog) && parsed.proofLog.length ? parsed.proofLog : DEFAULT_PROOF
+      };
+    }
+  } catch {
+    // ignore corrupt persisted state
+  }
+
+  return {
+    projectId: DEFAULT_PROJECT_ID,
+    autoRun: true,
+    queue: DEFAULT_TASKS,
+    phase: DEFAULT_PHASE,
+    metrics: {
+      refreshSuccesses: 0,
+      refreshFailures: 0,
+      lastHealthyAt: null,
+      lastSupervisorTickAt: null,
+      fallbackSince: null
+    },
+    blocker: null,
+    activeSlice: {
+      id: "product-proof-surface",
+      title: "In-product proof-of-work surface",
+      status: "running"
+    },
+    proofLog: DEFAULT_PROOF,
+    eventLog: []
+  };
+}
+
+function persistState(state) {
+  localStorage.setItem(ORCHESTRATION_KEY, JSON.stringify(state));
+}
+
+function queueToBuildTasks(queue = []) {
+  return queue.map((task) => ({
+    title: task.title,
+    detail: task.detail,
+    owner: task.owner,
+    dependsOn: task.dependsOn,
+    done: task.status === "done"
+  }));
+}
+
+function buildWorkflow(state) {
+  const activeOwner = state.phase?.owner || "BUILDER";
+  const activeStep = state.phase?.step || 1;
+  const roleTimer = state.blocker ? "Blocked" : state.autoRun ? "Execution active" : "Manual hold";
+
+  const roleMeta = {
+    BUILDER: { role: "Builder", health: "healthy" },
+    REVIEWER: { role: "Reviewer", health: "monitoring" },
+    AUDITOR: { role: "Auditor", health: "healthy" },
+    SUPERVISOR: { role: "Supervisor", health: "healthy" }
+  };
+
+  const steps = STEP_ORDER.map((ownerKey, index) => {
+    const meta = roleMeta[ownerKey];
+    const stepNumber = index + 1;
+    const isActive = stepNumber === activeStep;
+    const isComplete = stepNumber < activeStep;
+
+    return {
+      name: `Step ${stepNumber} — ${meta.role}`,
+      scheme: isActive ? state.phase?.scheme || "ARTIFACTS_REVIEWED" : "SCHEME_PENDING",
+      status: isComplete ? "Complete" : isActive ? state.phase?.status || "IN_PROGRESS" : "Queued",
+      complete: isComplete,
+      purpose: isActive
+        ? state.activeSlice?.title || `${meta.role} is executing the active Atlantis slice.`
+        : `${meta.role} takes over after the prior owner completes a real artifact-backed handoff.`,
+      ownerNotification: isActive ? state.phase?.nextTrigger || "handoff_pending" : "Await prior step completion",
+      sla: state.blocker ? "Needs intervention" : "Artifact-backed execution required",
+      watchdog: state.blocker ? state.blocker.code : "healthy",
+      doneWhen: [
+        `${meta.role} has touched the system before speaking`,
+        "A real artifact exists before step advancement",
+        `Scheme ladder progresses through ${SCHEME_ORDER.join(" → ")}`,
+        `${meta.role} completes with proof-backed handoff evidence`
+      ],
+      roles: STEP_ORDER.map((roleKey, roleIndex) => ({
+        role: roleMeta[roleKey].role,
+        owner: roleKey === activeOwner ? "Active" : roleIndex < index ? "Complete" : "Standby",
+        timer: roleKey === activeOwner && isActive ? roleTimer : roleIndex < index ? "done" : "queued",
+        health: roleKey === activeOwner && isActive ? (state.blocker ? "blocked" : roleMeta[roleKey].health) : roleMeta[roleKey].health,
+        done: roleIndex < index || (isComplete && roleKey === ownerKey)
+      }))
+    };
+  });
+
+  return [
+    {
+      name: state.phase?.phaseHuman || "Build",
+      objective: "Advance Atlantis through the standard engineering workflow with real artifacts at each step.",
+      status: state.phase?.status || "IN_PROGRESS",
+      active: true,
+      currentStep: `Step ${activeStep} — ${roleMeta[activeOwner]?.role || "Builder"}`,
+      schemeStandard: SCHEME_ORDER.join(" → "),
+      ownerNotification: "Post completion + next move to 1480062095348207648",
+      slaWatchdog: state.blocker ? `Blocked · ${state.blocker.code}` : "Execution proof required before speaking",
+      steps
+    }
+  ];
+}
+
+function appendEvent(state, event) {
+  state.eventLog = [
+    { at: new Date().toISOString(), ...event },
+    ...(state.eventLog || [])
+  ].slice(0, 40);
+}
+
+export function createOrchestrationService({ pollIntervalMs = 4000 } = {}) {
+  const state = readState();
+  persistState(state);
+
+  const touch = () => {
+    state.metrics.lastSupervisorTickAt = new Date().toISOString();
+    persistState(state);
+  };
+
+  const markTaskDone = (taskId) => {
+    const task = state.queue.find((item) => item.id === taskId);
+    if (task) task.status = "done";
+  };
+
+  const nextQueueTask = () => state.queue.find((item) => item.status !== "done") || null;
+
+  const syncFromRefresh = ({ ok, source, warning, error }) => {
+    touch();
+
+    if (ok) {
+      state.metrics.refreshSuccesses += 1;
+      state.metrics.lastHealthyAt = new Date().toISOString();
+
+      if (source === "openclaw-live") {
+        state.metrics.fallbackSince = null;
+        state.blocker = null;
+        state.phase.owner = state.phase.owner || "BUILDER";
+        state.phase.status = "IN_PROGRESS";
+        state.phase.lastProofEvent = "LIVE_REFRESH_OK";
+        state.phase.nextTrigger = nextQueueTask() ? "advance_next_slice" : "phase_completion_review";
+        appendEvent(state, { type: "LIVE_REFRESH_OK", detail: "Live feed refresh succeeded." });
+      } else {
+        state.metrics.fallbackSince = state.metrics.fallbackSince || new Date().toISOString();
+        state.phase.owner = state.phase.owner || "BUILDER";
+        state.phase.status = "IN_PROGRESS";
+        state.phase.lastProofEvent = "FALLBACK_ACTIVE";
+        state.phase.nextTrigger = "watchdog_monitoring";
+        appendEvent(state, { type: "FALLBACK_ACTIVE", detail: warning || "Fallback data in use." });
+      }
+    } else {
+      state.metrics.refreshFailures += 1;
+      state.phase.owner = "SUPERVISOR";
+      state.phase.status = "BLOCKED";
+      state.phase.lastProofEvent = `REFRESH_FAILURE:${error?.message || "unknown"}`;
+      state.phase.nextTrigger = "human_or_runtime_intervention";
+      state.blocker = {
+        code: "REFRESH_FAILURE",
+        detail: error?.message || "Unknown refresh failure",
+        since: state.blocker?.since || new Date().toISOString()
+      };
+      appendEvent(state, { type: "REFRESH_FAILURE", detail: error?.message || "Unknown refresh failure" });
+    }
+
+    markTaskDone("validator-gate");
+    markTaskDone("blocker-escalation");
+    persistState(state);
+  };
+
+  const runSupervisorTick = () => {
+    touch();
+    markTaskDone("persisted-state");
+    markTaskDone("next-slice-selector");
+    markTaskDone("event-emission");
+    markTaskDone("product-proof-surface");
+
+    const nextTask = nextQueueTask();
+    state.activeSlice = nextTask
+      ? { id: nextTask.id, title: nextTask.title, status: "ready" }
+      : { id: "phase-review", title: "Phase completion review", status: "ready" };
+
+    if (!state.autoRun) {
+      state.phase.owner = STEP_ORDER[Math.max(0, (state.phase.step || 1) - 1)] || "SUPERVISOR";
+      state.phase.status = "PAUSED";
+      state.phase.lastProofEvent = "AUTORUN_DISABLED";
+      state.phase.nextTrigger = "manual_resume";
+      persistState(state);
+      return state;
+    }
+
+    if (state.blocker) {
+      state.phase.owner = STEP_ORDER[Math.max(0, (state.phase.step || 1) - 1)] || "SUPERVISOR";
+      state.phase.status = "BLOCKED";
+      state.phase.nextTrigger = "blocker_clear";
+      persistState(state);
+      return state;
+    }
+
+    if (!nextTask) {
+      state.phase.step = 4;
+      state.phase.owner = "SUPERVISOR";
+      state.phase.scheme = "FINAL_VERDICT";
+      state.phase.status = "READY_FOR_PHASE_CLOSE";
+      state.phase.lastProofEvent = "QUEUE_EMPTY_REVIEW_READY";
+      state.phase.nextTrigger = "supervisor_closeout";
+      appendEvent(state, { type: "QUEUE_EMPTY_REVIEW_READY", detail: "All orchestration tasks are complete." });
+      persistState(state);
+      return state;
+    }
+
+    state.phase.step = 1;
+    state.phase.owner = "BUILDER";
+    state.phase.scheme = SCHEME_ORDER.find((scheme) => scheme === state.phase.scheme) || "ARTIFACTS_REVIEWED";
+    state.phase.status = "IN_PROGRESS";
+    state.phase.lastProofEvent = `NEXT_SLICE:${nextTask.id}`;
+    state.phase.nextTrigger = "refresh_validation";
+    appendEvent(state, { type: "NEXT_SLICE", detail: nextTask.title });
+    persistState(state);
+    return state;
+  };
+
+  const decorateProject = (project) => {
+    if (!project || project.id !== state.projectId) return project;
+
+    const queue = state.queue || [];
+    const completed = queue.filter((item) => item.status === "done").length;
+    const progress = queue.length ? Math.round((completed / queue.length) * 100) : project.progress || 0;
+
+    return {
+      ...project,
+      status: state.blocker ? "staging" : project.status || "in_motion",
+      phase: state.phase.phaseHuman,
+      progress,
+      activeScheme: {
+        ...(project.activeScheme || {}),
+        name: state.phase.scheme,
+        owner: `Step ${state.phase.step} — ${state.phase.owner}`,
+        elapsed: state.metrics.lastSupervisorTickAt ? new Date(state.metrics.lastSupervisorTickAt).toLocaleTimeString() : "Waiting",
+        sla: state.blocker ? "Blocked" : `${Math.round(pollIntervalMs / 1000)}s supervisor tick`,
+        watchdog: state.blocker ? state.blocker.code : "Execution active"
+      },
+      automationRules: {
+        ...(project.automationRules || {}),
+        completionGate: state.phase.stopTarget,
+        notifications: { channel: "1480062095348207648", trigger: "Scheme completion + next move" },
+        sla: { policy: state.blocker ? "Escalate on blocker" : "Every owner must touch system before speaking" },
+        watchdog: { status: state.blocker ? "BLOCKED" : "ACTIVE" },
+        notes: [
+          `Auto-run: ${state.autoRun ? "enabled" : "disabled"}`,
+          `Last proof: ${state.phase.lastProofEvent}`,
+          `Next trigger: ${state.phase.nextTrigger}`,
+          `Scheme order: ${SCHEME_ORDER.join(" → ")}`
+        ]
+      },
+      workflow: buildWorkflow(state),
+      buildTasks: queueToBuildTasks(queue),
+      proof: state.proofLog || [],
+      orchestration: state
+    };
+  };
+
+  return {
+    getState: () => structuredClone(state),
+    setAutoRun(enabled) {
+      state.autoRun = Boolean(enabled);
+      persistState(state);
+      return this.getState();
+    },
+    runSupervisorTick,
+    syncFromRefresh,
+    decorateProject,
+    persist() {
+      persistState(state);
+    }
+  };
+}
